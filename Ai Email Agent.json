      "id": "252b7cd4-942d-46d8-bce9-45ae21d13ec5",
      "name": "Structured Output Parser"
    },
    {
      "parameters": {
        "jsCode": "// Get ALL input items (not just first)\nconst items = $input.all();\n\n// Function to format a single email body\nfunction formatEmail(body) {\n    if (!body) return \"\";\n    \n    let formatted = body\n        .replace(/\\\\\\\\n/g, '\\n')\n        .replace(/\\\\n/g, '\\n')\n        .replace(/\\n{3,}/g, '\\n\\n')\n        .replace(/-\\s+/g, '- ')\n        .trim();\n    \n    return formatted;\n}\n\n// Function to extract value safely from any structure\nfunction extractValue(data, fieldName) {\n    if (!data) return null;\n    if (data[fieldName]) return data[fieldName];\n    if (data.output && data.output[fieldName]) return data.output[fieldName];\n    if (data.body && fieldName === 'body') return data.body;\n    if (data.subject && fieldName === 'subject') return data.subject;\n    return null;\n}\n\n// Process EACH item and return ALL items\nconst formattedItems = [];\n\nfor (let i = 0; i < items.length; i++) {\n    const data = items[i].json;\n    \n    // Extract subject and body\n    let subject = extractValue(data, 'subject') || \"No Subject\";\n    let emailBody = extractValue(data, 'body') || \"\";\n    \n    // If body is empty, try to get from other fields\n    if (!emailBody && data.output) {\n        emailBody = data.output.body || data.output.message || \"\";\n    }\n    if (!emailBody && data.text) {\n        emailBody = data.text;\n    }\n    \n    // Add formatted email to results\n    formattedItems.push({\n        json: {\n            subject: subject,\n            body: formatEmail(emailBody),\n            original_subject: subject,\n            original_body: emailBody,\n            email: data.email || data.to || \"\",\n            company: data.company_name || data.Company || \"\",\n            index: i + 1,\n            formatted_at: new Date().toISOString()\n        }\n    });\n}\n\n// Return ALL formatted items (same count as input)\nreturn formattedItems;"
      },
